{
  "name": "gedify-nopp",
  "version": "0.1.0",
  "private": true,
  "description": "Gedify autonome (sans Paperless) — moteur documentaire local embarqué.",
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "prisma generate && next build",
    "start": "next start -p 3200",
    "lint": "eslint",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:sql": "node scripts/gen-sql.mjs",
    "build:scripts": "node scripts/build-scripts.mjs",
    "gedify:db:check": "node scripts/gedify-db-check.mjs",
    "gedify:db:push": "node scripts/gedify-db-push.mjs",
    "gedify:storage:inspect": "node scripts/gedify-storage-inspect.mjs",
    "gedify:storage:doctor": "node scripts/gedify-storage-doctor.mjs",
    "gedify:auth:doctor": "node --experimental-sqlite scripts/gedify-auth-doctor.mjs",
