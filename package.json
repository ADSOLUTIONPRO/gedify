{
  "name": "gedify-nopp",
  "version": "0.1.0",
  "private": true,
  "description": "Gedify autonome (sans Paperless) — moteur documentaire local embarqué.",
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "prisma generate && next build",
    "start": "next start -p 3200",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:sql": "node scripts/gen-sql.mjs",
    "build:scripts": "node scripts/build-scripts.mjs",
    "gedify:db:check": "node scripts/gedify-db-check.mjs",
    "gedify:db:push": "node scripts/gedify-db-push.mjs",
    "gedify:storage:inspect": "node scripts/gedify-storage-inspect.mjs",
    "gedify:storage:doctor": "node scripts/gedify-storage-doctor.mjs",
    "gedify:previews:inspect": "node scripts/gedify-previews-doctor.mjs",
    "gedify:previews:cleanup-orphans": "node scripts/gedify-previews-doctor.mjs --clean",
    "gedify:pipeline:inspect": "node scripts/gedify-pipeline-doctor.mjs",
    "gedify:pipeline:retry-failed": "node scripts/gedify-pipeline-doctor.mjs --retry-failed",
    "gedify:duplicates:inspect": "node scripts/gedify-duplicates-doctor.mjs",
    "gedify:backup-json": "node scripts/gedify-backup-json.mjs",
    "gedify:migrate-json:dry-run": "node scripts/gedify-migrate-json.mjs --dry-run",
    "gedify:migrate-json": "node scripts/gedify-migrate-json.mjs"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "docx": "^9.7.0",
    "imapflow": "^1.3.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "mailparser": "^3.9.8",
    "minisearch": "^7.1.1",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1",
    "tesseract.js-core": "^5.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
