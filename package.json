    "gedify:mails:inspect": "node scripts/gedify-mails-doctor.mjs",
    "gedify:mails:tokens:inspect": "node scripts/gedify-mails-doctor.mjs --tokens",
    "gedify:mails:links:inspect": "node scripts/gedify-mails-doctor.mjs --links",
    "gedify:mails:contacts:dedupe": "node scripts/gedify-mails-doctor.mjs --contacts-dedupe",
    "gedify:backup-json": "node scripts/gedify-backup-json.mjs",
    "gedify:migrate-json:dry-run": "node scripts/gedify-migrate-json.mjs --dry-run",
    "gedify:migrate-json": "node scripts/gedify-migrate-json.mjs"
