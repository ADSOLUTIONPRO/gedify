    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "docx": "^9.7.0",
    "imapflow": "^1.3.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "minisearch": "^7.1.1",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1",
    "tesseract.js-core": "^5.1.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
