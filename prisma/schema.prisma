// Schéma PostgreSQL de Gedify (intégration progressive, sans casser le JSON).
// Chaque table a des colonnes « requêtables » + une colonne `raw Json` qui
// conserve l'objet JSON d'origine INTÉGRAL → migration sans perte de données.
// Prisma 7 : client TypeScript + driver adapter (pg), pas de moteur natif runtime.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * ── Documents & taxonomies ────────────────────────────────────────────────
 */

model Document {
  id               Int       @id
  title            String?
  content          String?   @db.Text
  created          DateTime?
  createdDate      String?   @map("created_date")
  added            DateTime?
  modified         DateTime?
  correspondentId  Int?      @map("correspondent_id")
  documentTypeId   Int?      @map("document_type_id")
  storagePath      String?   @map("storage_path")
  mimeType         String?   @map("mime_type")
  checksum         String?
  storedFilename   String?   @map("stored_filename")
  originalFileName String?   @map("original_file_name")
  pageCount        Int?      @map("page_count")
  deleted          Boolean   @default(false)
  deletedAt        DateTime? @map("deleted_at")
  raw              Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([correspondentId])
  @@index([documentTypeId])
  @@index([deleted])
  @@index([checksum])
  @@map("documents")
}

model DocumentFile {
  id         String  @id
  documentId Int     @map("document_id")
  kind       String  @default("original") // original | thumbnail
  filename   String?
  mimeType   String? @map("mime_type")
  sizeBytes  Int?    @map("size_bytes")
  raw        Json?

  @@index([documentId])
  @@map("document_files")
}

model DocumentVersion {
  id         String   @id
  documentId Int      @map("document_id")
  label      String?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("document_versions")
}

model DocumentOcr {
  documentId Int     @id @map("document_id")
  content    String? @db.Text
  raw        Json?

  @@map("document_ocr")
}

model DocumentAiAnalysis {
  id         String    @id
  documentId Int       @map("document_id")
  summary    String?   @db.Text
  confidence String?
  source     String?
  analyzedAt DateTime? @map("analyzed_at")
  raw        Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@map("document_ai_analyses")
}

model DocumentAiSuggestion {
  id             String   @id
  documentId     Int?     @map("document_id")
  analysisId     String?  @map("analysis_id")
  suggestionType String?  @map("suggestion_type")
  fieldName      String?  @map("field_name")
  suggestedValue String?  @map("suggested_value") @db.Text
  confidence     String?
  source         String?
  applied        Boolean  @default(false)
  rawPayload     Json?    @map("raw_payload")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([documentId])
  @@index([analysisId])
  @@map("document_ai_suggestions")
}

model Tag {
  id        Int     @id
  name      String?
  slug      String?
  color     String?
  textColor String? @map("text_color")
  raw       Json?

  @@map("tags")
}

model DocumentTag {
  documentId Int @map("document_id")
  tagId      Int @map("tag_id")

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tags")
}

model DocumentType {
  id   Int     @id
  name String?
  slug String?
  raw  Json?

  @@map("document_types")
}

model Correspondent {
  id   Int     @id
  name String?
  slug String?
  raw  Json?

  @@map("correspondents")
}

model DocumentCorrespondent {
  documentId      Int     @map("document_id")
  correspondentId Int     @map("correspondent_id")
  role            String? // primary | secondary

  @@id([documentId, correspondentId])
  @@index([correspondentId])
  @@map("document_correspondents")
}

/**
 * ── Dossiers / projets ────────────────────────────────────────────────────
 */

model Folder {
  id        String   @id
  parentId  String?  @map("parent_id")
  name      String?
  slug      String?
  color     String?
  category  String?
  status    String?
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("folders")
}

model FolderDocument {
  folderId   String @map("folder_id")
  documentId Int    @map("document_id")

  @@id([folderId, documentId])
  @@index([documentId])
  @@map("folder_documents")
}

/**
 * ── Finances ──────────────────────────────────────────────────────────────
 */

model BudgetEntry {
  id               String   @id
  kind             String?
  direction        String?
  label            String?
  amount           Float?
  amountPaid       Float?   @map("amount_paid")
  dueDate          String?  @map("due_date")
  status           String?
  categoryId       String?  @map("category_id")
  categoryName     String?  @map("category_name")
  sourceDocumentId Int?     @map("source_document_id")
  raw              Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([direction])
  @@index([sourceDocumentId])
  @@map("budget_entries")
}

model BudgetPayment {
  id            String  @id
  budgetEntryId String  @map("budget_entry_id")
  amount        Float?
  date          String?
  account       String?
  raw           Json?

  @@index([budgetEntryId])
  @@map("budget_payments")
}

/**
 * ── Mails ─────────────────────────────────────────────────────────────────
 */

model Mail {
  id             String    @id
  accountId      String?   @map("account_id")
  messageId      String?   @map("message_id")
  threadId       String?   @map("thread_id")
  fromAddr       String?   @map("from_addr")
  toAddr         String?   @map("to_addr")
  subject        String?
  date           DateTime?
  snippet        String?   @db.Text
  body           String?   @db.Text
  hasAttachments Boolean   @default(false) @map("has_attachments")
  raw            Json?

  @@index([accountId])
  @@index([threadId])
  @@map("mails")
}

model MailAttachment {
  id       String  @id
  mailId   String? @map("mail_id")
  threadId String? @map("thread_id")
  filename String?
  mimeType String? @map("mime_type")
  raw      Json?

  @@index([mailId])
  @@map("mail_attachments")
}

model MailDocumentLink {
  id         String   @id
  accountId  String?  @map("account_id")
  mailId     String?  @map("mail_id")
  threadId   String?  @map("thread_id")
  documentId Int?     @map("document_id")
  filename   String?
  status     String?
  kind       String? // attachment | ged-link
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([threadId])
  @@index([documentId])
  @@map("mail_document_links")
}

/**
 * ── Rappels / tâches ──────────────────────────────────────────────────────
 */

model Reminder {
  id              String    @id
  title           String?
  remindAt        DateTime? @map("remind_at")
  status          String?
  documentId      Int?      @map("document_id")
  financialItemId String?   @map("financial_item_id")
  raw             Json?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([documentId])
  @@map("reminders")
}

model Task {
  id        String   @id
  title     String?
  status    String?
  priority  String?
  dueDate   String?  @map("due_date")
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("tasks")
}

/**
 * ── Divers ────────────────────────────────────────────────────────────────
 */

model Signature {
  id         String   @id
  scope      String? // document | email | writer
  documentId Int?     @map("document_id")
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("signatures")
}

model LearnedTemplate {
  id        String   @id
  label     String?
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("learned_templates")
}

model AssistantActionLog {
  id         String   @id @default(cuid())
  type       String?
  message    String?  @db.Text
  documentId Int?     @map("document_id")
  user       String?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("assistant_action_logs")
}

model ActivityLog {
  id         String   @id
  level      String?
  source     String?
  message    String?  @db.Text
  documentId Int?     @map("document_id")
  projectId  String?  @map("project_id")
  user       String?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("activity_logs")
}

model User {
  id           Int       @id
  username     String    @unique
  email        String?   @unique
  passwordHash String?   @map("password_hash")
  isSuperuser  Boolean   @default(false) @map("is_superuser")
  isActive     Boolean   @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("users")
}

model Counter {
  name      String   @id
  value     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("counters")
}

model DocumentTitleOverride {
  documentId Int      @id @map("document_id")
  title      String?
  source     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("document_title_overrides")
}

model EmailContact {
  id          String    @id
  name        String?
  email       String?
  displayName String?   @map("display_name")
  source      String?
  lastSeenAt  DateTime? @map("last_seen_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([email])
  @@map("email_contacts")
}

model MailAccount {
  id          String    @id
  provider    String?
  email       String?
  displayName String?   @map("display_name")
  status      String?
  scopes      Json?
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("mail_accounts")
}

model MailOauthToken {
  id                    String    @id
  accountId             String?   @map("account_id")
  provider              String?
  email                 String?
  accessTokenEncrypted  String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  expiryDate            DateTime? @map("expiry_date")
  scope                 String?   @db.Text
  tokenType             String?   @map("token_type")
  metadata              Json?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  @@index([accountId])
  @@map("mail_oauth_tokens")
}

model SavedSignature {
  id        String    @id
  label     String?
  type      String?
  imagePath String?   @map("image_path")
  imageData String?   @map("image_data") @db.Text
  width     Int?
  height    Int?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("saved_signatures")
}

model HiddenSender {
  id        String    @id
  email     String?
  domain    String?
  reason    String?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([email])
  @@map("hidden_senders")
}

model CustomField {
  id        Int       @id
  name      String?
  label     String?
  type      String?
  options   Json?
  required  Boolean   @default(false)
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("custom_fields")
}

model Setting {
  key   String @id
  value Json

  @@map("settings")
}

/**
 * ── Multi-tenant (FONDATION — Phase 1) ─────────────────────────────────────
 * Tables additives, INACTIVES tant que MULTI_TENANT n'est pas activé (env).
 * Aucun impact sur main / Synology / local : non utilisées en mode mono-tenant.
 * On NE branche PAS encore `tenant_id` sur les tables métier (étape ultérieure).
 */

model Tenant {
  id        String   @id // slug = id (ex. "azserver-staging")
  name      String?
  slug      String   @unique
  plan      String? // internal | free | pro | enterprise
  status    String? // active | suspended | archived
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenants")
}

model Membership {
  id        String   @id // `${tenantId}:${userId}`
  userId    Int      @map("user_id")
  tenantId  String   @map("tenant_id")
  role      String // owner | admin | member | viewer
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

model TenantSettings {
  id                 String   @id // = tenantId (une ligne par tenant)
  tenantId           String   @unique @map("tenant_id")
  maxUsers           Int?     @map("max_users")
  maxDocuments       Int?     @map("max_documents")
  maxStorageMb       Int?     @map("max_storage_mb")
  aiEnabled          Boolean  @default(true) @map("ai_enabled")
  ocrEnabled         Boolean  @default(true) @map("ocr_enabled")
  emailImportEnabled Boolean  @default(true) @map("email_import_enabled")
  onlyofficeEnabled  Boolean  @default(true) @map("onlyoffice_enabled")
  raw                Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenant_settings")
}
