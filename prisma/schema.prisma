// Schéma PostgreSQL de Gedify (intégration progressive, sans casser le JSON).
// Chaque table a des colonnes « requêtables » + une colonne `raw Json` qui
// conserve l'objet JSON d'origine INTÉGRAL → migration sans perte de données.
// Prisma 7 : client TypeScript + driver adapter (pg), pas de moteur natif runtime.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * ── Documents & taxonomies ────────────────────────────────────────────────
 */

model Document {
  id               Int       @id
  title            String?
  content          String?   @db.Text
  created          DateTime?
  createdDate      String?   @map("created_date")
  added            DateTime?
  modified         DateTime?
  correspondentId  Int?      @map("correspondent_id")
  documentTypeId   Int?      @map("document_type_id")
  storagePath      String?   @map("storage_path")
  mimeType         String?   @map("mime_type")
  checksum         String?
  storedFilename   String?   @map("stored_filename")
  originalFileName String?   @map("original_file_name")
  pageCount        Int?      @map("page_count")
  deleted          Boolean   @default(false)
  deletedAt        DateTime? @map("deleted_at")
  raw              Json?
  tenantId         String?   @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([correspondentId])
  @@index([documentTypeId])
  @@index([deleted])
  @@index([checksum])
  @@index([tenantId])
  @@map("documents")
}

model DocumentFile {
  id         String  @id
  documentId Int     @map("document_id")
  kind       String  @default("original") // original | thumbnail
  filename   String?
  mimeType   String? @map("mime_type")
  sizeBytes  Int?    @map("size_bytes")
  raw        Json?
  tenantId   String? @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)

  @@index([documentId])
  @@index([tenantId])
  @@map("document_files")
}

model DocumentVersion {
  id         String   @id
  documentId Int      @map("document_id")
  label      String?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("document_versions")
}

model DocumentOcr {
  documentId Int     @id @map("document_id")
  content    String? @db.Text
  raw        Json?

  @@map("document_ocr")
}

model DocumentAiAnalysis {
  id         String    @id
  documentId Int       @map("document_id")
  summary    String?   @db.Text
  confidence String?
  source     String?
  analyzedAt DateTime? @map("analyzed_at")
  raw        Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@map("document_ai_analyses")
}

model DocumentAiSuggestion {
  id             String   @id
  documentId     Int?     @map("document_id")
  analysisId     String?  @map("analysis_id")
  suggestionType String?  @map("suggestion_type")
  fieldName      String?  @map("field_name")
  suggestedValue String?  @map("suggested_value") @db.Text
  confidence     String?
  source         String?
  applied        Boolean  @default(false)
  rawPayload     Json?    @map("raw_payload")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([documentId])
  @@index([analysisId])
  @@map("document_ai_suggestions")
}

model Tag {
  id        Int     @id
  name      String?
  slug      String?
  color     String?
  textColor String? @map("text_color")
  raw       Json?
  tenantId  String? @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)

  @@index([tenantId])
  @@map("tags")
}

model DocumentTag {
  documentId Int @map("document_id")
  tagId      Int @map("tag_id")

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tags")
}

model DocumentType {
  id       Int     @id
  name     String?
  slug     String?
  raw      Json?
  tenantId String? @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)

  @@index([tenantId])
  @@map("document_types")
}

model Correspondent {
  id       Int     @id
  name     String?
  slug     String?
  raw      Json?
  tenantId String? @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)

  @@index([tenantId])
  @@map("correspondents")
}

model DocumentCorrespondent {
  documentId      Int     @map("document_id")
  correspondentId Int     @map("correspondent_id")
  role            String? // primary | secondary
  tenantId        String? @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)

  @@id([documentId, correspondentId])
  @@index([correspondentId])
  @@index([tenantId])
  @@map("document_correspondents")
}

/**
 * ── Dossiers / projets ────────────────────────────────────────────────────
 */

model Folder {
  id        String   @id
  parentId  String?  @map("parent_id")
  name      String?
  slug      String?
  color     String?
  category  String?
  status    String?
  raw       Json?
  tenantId  String?  @map("tenant_id") // multi-tenant Phase 2 (nullable, gated MULTI_TENANT)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([tenantId])
  @@map("folders")
}

model FolderDocument {
  folderId   String @map("folder_id")
  documentId Int    @map("document_id")

  @@id([folderId, documentId])
  @@index([documentId])
  @@map("folder_documents")
}

/**
 * ── Finances ──────────────────────────────────────────────────────────────
 */

model BudgetEntry {
  id               String   @id
  kind             String?
  direction        String?
  label            String?
  amount           Float?
  amountPaid       Float?   @map("amount_paid")
  dueDate          String?  @map("due_date")
  status           String?
  categoryId       String?  @map("category_id")
  categoryName     String?  @map("category_name")
  sourceDocumentId Int?     @map("source_document_id")
  raw              Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([direction])
  @@index([sourceDocumentId])
  @@map("budget_entries")
}

model BudgetPayment {
  id            String  @id
  budgetEntryId String  @map("budget_entry_id")
  amount        Float?
  date          String?
  account       String?
  raw           Json?

  @@index([budgetEntryId])
  @@map("budget_payments")
}

/**
 * ── Mails ─────────────────────────────────────────────────────────────────
 */

model Mail {
  id             String    @id
  accountId      String?   @map("account_id")
  messageId      String?   @map("message_id")
  threadId       String?   @map("thread_id")
  fromAddr       String?   @map("from_addr")
  toAddr         String?   @map("to_addr")
  subject        String?
  date           DateTime?
  snippet        String?   @db.Text
  body           String?   @db.Text
  hasAttachments Boolean   @default(false) @map("has_attachments")
  raw            Json?

  @@index([accountId])
  @@index([threadId])
  @@map("mails")
}

model MailAttachment {
  id       String  @id
  mailId   String? @map("mail_id")
  threadId String? @map("thread_id")
  filename String?
  mimeType String? @map("mime_type")
  raw      Json?

  @@index([mailId])
  @@map("mail_attachments")
}

model MailDocumentLink {
  id         String   @id
  accountId  String?  @map("account_id")
  mailId     String?  @map("mail_id")
  threadId   String?  @map("thread_id")
  documentId Int?     @map("document_id")
  filename   String?
  status     String?
  kind       String? // attachment | ged-link
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([threadId])
  @@index([documentId])
  @@map("mail_document_links")
}

/**
 * ── Rappels / tâches ──────────────────────────────────────────────────────
 */

model Reminder {
  id              String    @id
  title           String?
  remindAt        DateTime? @map("remind_at")
  status          String?
  documentId      Int?      @map("document_id")
  financialItemId String?   @map("financial_item_id")
  raw             Json?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([documentId])
  @@map("reminders")
}

model Task {
  id        String   @id
  title     String?
  status    String?
  priority  String?
  dueDate   String?  @map("due_date")
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("tasks")
}

/**
 * ── Divers ────────────────────────────────────────────────────────────────
 */

model Signature {
  id         String   @id
  scope      String? // document | email | writer
  documentId Int?     @map("document_id")
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("signatures")
}

model LearnedTemplate {
  id        String   @id
  label     String?
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("learned_templates")
}

model AssistantActionLog {
  id         String   @id @default(cuid())
  type       String?
  message    String?  @db.Text
  documentId Int?     @map("document_id")
  user       String?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("assistant_action_logs")
}

model ActivityLog {
  id         String   @id
  level      String?
  source     String?
  message    String?  @db.Text
  documentId Int?     @map("document_id")
  projectId  String?  @map("project_id")
  user       String?
  raw        Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("activity_logs")
}

model User {
  id           Int       @id
  username     String    @unique
  email        String?   @unique
  passwordHash String?   @map("password_hash")
  isSuperuser  Boolean   @default(false) @map("is_superuser")
  isActive     Boolean   @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("users")
}

model Counter {
  name      String   @id
  value     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("counters")
}

model DocumentTitleOverride {
  documentId Int      @id @map("document_id")
  title      String?
  source     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("document_title_overrides")
}

model EmailContact {
  id          String    @id
  name        String?
  email       String?
  displayName String?   @map("display_name")
  source      String?
  lastSeenAt  DateTime? @map("last_seen_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([email])
  @@map("email_contacts")
}

model MailAccount {
  id          String    @id
  provider    String?
  email       String?
  displayName String?   @map("display_name")
  status      String?
  scopes      Json?
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("mail_accounts")
}

model MailOauthToken {
  id                    String    @id
  accountId             String?   @map("account_id")
  provider              String?
  email                 String?
  accessTokenEncrypted  String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  expiryDate            DateTime? @map("expiry_date")
  scope                 String?   @db.Text
  tokenType             String?   @map("token_type")
  metadata              Json?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  @@index([accountId])
  @@map("mail_oauth_tokens")
}

model SavedSignature {
  id        String    @id
  label     String?
  type      String?
  imagePath String?   @map("image_path")
  imageData String?   @map("image_data") @db.Text
  width     Int?
  height    Int?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("saved_signatures")
}

model HiddenSender {
  id        String    @id
  email     String?
  domain    String?
  reason    String?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([email])
  @@map("hidden_senders")
}

model CustomField {
  id        Int       @id
  name      String?
  label     String?
  type      String?
  options   Json?
  required  Boolean   @default(false)
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("custom_fields")
}

model Setting {
  key   String @id
  value Json

  @@map("settings")
}

/**
 * ── Multi-tenant (FONDATION — Phase 1) ─────────────────────────────────────
 * Tables additives, INACTIVES tant que MULTI_TENANT n'est pas activé (env).
 * Aucun impact sur main / Synology / local : non utilisées en mode mono-tenant.
 * On NE branche PAS encore `tenant_id` sur les tables métier (étape ultérieure).
 */

model Tenant {
  id        String   @id // slug = id (ex. "azserver-staging")
  name      String?
  slug      String   @unique
  plan      String? // internal | free | pro | enterprise
  status    String? // active | suspended | archived
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenants")
}

model Membership {
  id        String   @id // `${tenantId}:${userId}`
  userId    Int      @map("user_id")
  tenantId  String   @map("tenant_id")
  role      String // owner | admin | member | viewer
  raw       Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

model TenantSettings {
  id                 String   @id // = tenantId (une ligne par tenant)
  tenantId           String   @unique @map("tenant_id")
  maxUsers           Int?     @map("max_users")
  maxDocuments       Int?     @map("max_documents")
  maxStorageMb       Int?     @map("max_storage_mb")
  aiEnabled          Boolean  @default(true) @map("ai_enabled")
  ocrEnabled         Boolean  @default(true) @map("ocr_enabled")
  emailImportEnabled Boolean  @default(true) @map("email_import_enabled")
  onlyofficeEnabled  Boolean  @default(true) @map("onlyoffice_enabled")
  featuresOverride   Json?    @map("features_override") // surcharge fine de features par tenant
  raw                Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

/**
 * ── Abonnements / facturation (Phase 8 — préparation, compatible Stripe) ──
 * Additif, inactif tant que MULTI_TENANT n'est pas activé. Aucun appel Stripe.
 */

model Subscription {
  id                     String    @id
  tenantId               String    @map("tenant_id")
  plan                   String?
  status                 String? // trialing|active|past_due|canceled|unpaid|paused|incomplete
  provider               String    @default("manual") // manual|stripe
  providerCustomerId     String?   @map("provider_customer_id")
  providerSubscriptionId String?   @map("provider_subscription_id")
  currentPeriodStart     DateTime? @map("current_period_start")
  currentPeriodEnd       DateTime? @map("current_period_end")
  trialStart             DateTime? @map("trial_start")
  trialEnd               DateTime? @map("trial_end")
  cancelAt               DateTime? @map("cancel_at")
  canceledAt             DateTime? @map("canceled_at")
  // Liens commerciaux (gratuités / promos) — cf. SubscriptionGrant / PromoCode.
  manualGrantId          String?   @map("manual_grant_id")
  promoCodeId            String?   @map("promo_code_id")
  discountUntil          DateTime? @map("discount_until")
  freeUntil              DateTime? @map("free_until")
  isFreeForever          Boolean   @default(false) @map("is_free_forever")
  raw                    Json?
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id                String    @id
  tenantId          String    @map("tenant_id")
  subscriptionId    String?   @map("subscription_id")
  provider          String    @default("manual")
  providerInvoiceId String?   @map("provider_invoice_id")
  status            String? // draft|issued|paid|void|canceled|refunded|uncollectible
  amountDue         Int?      @map("amount_due") // cents
  amountPaid        Int?      @map("amount_paid") // cents
  currency          String?   @default("EUR")
  dueDate           DateTime? @map("due_date")
  paidAt            DateTime? @map("paid_at")
  hostedInvoiceUrl  String?   @map("hosted_invoice_url")
  invoicePdf        String?   @map("invoice_pdf")
  raw               Json?
  // ── Facture « réelle » (Module facturation) ──
  invoiceNumber     String?   @unique @map("invoice_number")
  billingProfileId  String?   @map("billing_profile_id")
  templateId        String?   @map("template_id")
  type              String?   @default("invoice") // invoice|credit_note|proforma
  creditNoteOfId    String?   @map("credit_note_of_id")
  issueDate         DateTime? @map("issue_date")
  subtotalHtCents   Int?      @map("subtotal_ht_cents")
  discountCents     Int?      @default(0) @map("discount_cents")
  taxCents          Int?      @default(0) @map("tax_cents")
  totalTtcCents     Int?      @map("total_ttc_cents")
  vatRate           Float?    @map("vat_rate")
  vatRegime         String?   @map("vat_regime")
  buyerName         String?   @map("buyer_name")
  buyerLegalName    String?   @map("buyer_legal_name")
  buyerEmail        String?   @map("buyer_email")
  buyerAddressLine1 String?   @map("buyer_address_line1")
  buyerAddressLine2 String?   @map("buyer_address_line2")
  buyerPostalCode   String?   @map("buyer_postal_code")
  buyerCity         String?   @map("buyer_city")
  buyerCountry      String?   @map("buyer_country")
  buyerSiren        String?   @map("buyer_siren")
  buyerSiret        String?   @map("buyer_siret")
  buyerVatNumber    String?   @map("buyer_vat_number")
  periodStart       DateTime? @map("period_start")
  periodEnd         DateTime? @map("period_end")
  htmlUrl           String?   @map("html_url")
  pdfUrl            String?   @map("pdf_url")
  legalMentionsSnapshot Json? @map("legal_mentions_snapshot")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLine {
  id              String   @id
  invoiceId       String   @map("invoice_id")
  description     String?
  quantity        Float    @default(1)
  unitPriceHtCents Int     @default(0) @map("unit_price_ht_cents")
  discountCents   Int      @default(0) @map("discount_cents")
  vatRate         Float?   @map("vat_rate")
  taxCents        Int      @default(0) @map("tax_cents")
  totalHtCents    Int      @default(0) @map("total_ht_cents")
  totalTtcCents   Int      @default(0) @map("total_ttc_cents")
  periodStart     DateTime? @map("period_start")
  periodEnd       DateTime? @map("period_end")
  sortOrder       Int      @default(0) @map("sort_order")
  raw             Json?

  @@index([invoiceId])
  @@map("invoice_lines")
}

model BillingProfile {
  id                          String   @id
  profileName                 String   @map("profile_name")
  companyName                 String   @map("company_name")
  legalName                   String?  @map("legal_name")
  legalForm                   String?  @map("legal_form")
  siren                       String?
  siret                       String?
  vatNumber                   String?  @map("vat_number")
  rcsCity                     String?  @map("rcs_city")
  rcsNumber                   String?  @map("rcs_number")
  rmNumber                    String?  @map("rm_number")
  apeNaf                      String?  @map("ape_naf")
  shareCapital                String?  @map("share_capital")
  addressLine1                String   @map("address_line1")
  addressLine2                String?  @map("address_line2")
  postalCode                  String   @map("postal_code")
  city                        String
  country                     String   @default("France")
  email                       String
  phone                       String?
  website                     String?
  logoUrl                     String?  @map("logo_url")
  signatureUrl                String?  @map("signature_url")
  iban                        String?
  bic                         String?
  paymentTermsDays            Int      @default(30) @map("payment_terms_days")
  latePaymentRate             String?  @map("late_payment_rate")
  fixedRecoveryIndemnityCents Int      @default(4000) @map("fixed_recovery_indemnity_cents")
  vatRegime                   String   @default("standard") @map("vat_regime") // standard|franchise_base|exempt|reverse_charge|intra_eu
  defaultVatRate              Float?   @map("default_vat_rate")
  invoicePrefix               String   @default("FAC") @map("invoice_prefix")
  creditNotePrefix            String   @default("AVOIR") @map("credit_note_prefix")
  nextInvoiceNumber           Int      @default(1) @map("next_invoice_number")
  nextCreditNoteNumber        Int      @default(1) @map("next_credit_note_number")
  isDefault                   Boolean  @default(false) @map("is_default")
  legalFooterHtml             String?  @map("legal_footer_html")
  termsFooterHtml             String?  @map("terms_footer_html")
  raw                         Json?
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("billing_profiles")
}

model InvoiceTemplate {
  id                 String   @id
  name               String
  isDefault          Boolean  @default(false) @map("is_default")
  locale             String   @default("fr-FR")
  currency           String   @default("EUR")
  primaryColor       String?  @map("primary_color")
  secondaryColor     String?  @map("secondary_color")
  fontFamily         String?  @map("font_family")
  logoPosition       String?  @map("logo_position")
  showLogo           Boolean  @default(true) @map("show_logo")
  showPaymentDetails Boolean  @default(true) @map("show_payment_details")
  showLegalFooter    Boolean  @default(true) @map("show_legal_footer")
  showQrCode         Boolean  @default(false) @map("show_qr_code")
  headerHtml         String?  @map("header_html")
  footerHtml         String?  @map("footer_html")
  customCss          String?  @map("custom_css")
  raw                Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("invoice_templates")
}

model PaymentEvent {
  id              String    @id
  tenantId        String?   @map("tenant_id")
  provider        String    @default("manual")
  eventType       String?   @map("event_type")
  providerEventId String?   @map("provider_event_id")
  processedAt     DateTime? @map("processed_at")
  raw             Json?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("payment_events")
}

/**
 * ── Plans administrables, codes promo, gratuités (Phase 8 — complément) ────
 */

model SaasPlan {
  id                  String   @id
  code                String   @unique // free|test|pro|business|internal|custom_xxx
  name                String?
  description         String?
  isActive            Boolean  @default(true) @map("is_active")
  isPublic            Boolean  @default(false) @map("is_public")
  isDefault           Boolean  @default(false) @map("is_default")
  sortOrder           Int      @default(0) @map("sort_order")
  monthlyPriceCents   Int?     @map("monthly_price_cents")
  yearlyPriceCents    Int?     @map("yearly_price_cents")
  currency            String   @default("EUR")
  maxUsers            Int?     @map("max_users")
  maxDocuments        Int?     @map("max_documents")
  maxStorageMb        Int?     @map("max_storage_mb")
  aiEnabled           Boolean  @default(true) @map("ai_enabled")
  ocrEnabled          Boolean  @default(true) @map("ocr_enabled")
  emailImportEnabled  Boolean  @default(false) @map("email_import_enabled")
  onlyofficeEnabled   Boolean  @default(true) @map("onlyoffice_enabled")
  supportLevel        String?  @map("support_level")
  features            Json?    // feature flags du plan (cf. src/lib/saas/features.ts)
  stripeProductId     String?  @map("stripe_product_id")
  stripeMonthlyPriceId String? @map("stripe_monthly_price_id")
  stripeYearlyPriceId String?  @map("stripe_yearly_price_id")
  raw                 Json?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("saas_plans")
}

model PromoCode {
  id                    String    @id
  code                  String    @unique
  name                  String?
  description           String?
  discountType          String?   @map("discount_type") // percent|amount|free_period|free_forever
  percentOff            Int?      @map("percent_off")
  amountOffCents        Int?      @map("amount_off_cents")
  currency              String    @default("EUR")
  freeDurationCount     Int?      @map("free_duration_count")
  freeDurationUnit      String?   @map("free_duration_unit") // day|month|year|lifetime
  appliesToPlan         String?   @map("applies_to_plan")
  maxRedemptions        Int?      @map("max_redemptions")
  redeemedCount         Int       @default(0) @map("redeemed_count")
  startsAt              DateTime? @map("starts_at")
  expiresAt             DateTime? @map("expires_at")
  isActive              Boolean   @default(true) @map("is_active")
  stripeCouponId        String?   @map("stripe_coupon_id")
  stripePromotionCodeId String?   @map("stripe_promotion_code_id")
  raw                   Json?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("promo_codes")
}

model PromoRedemption {
  id             String    @id
  promoCodeId    String    @map("promo_code_id")
  tenantId       String    @map("tenant_id")
  userId         Int?      @map("user_id")
  subscriptionId String?   @map("subscription_id")
  redeemedAt     DateTime  @default(now()) @map("redeemed_at")
  expiresAt      DateTime? @map("expires_at")
  raw            Json?

  @@index([promoCodeId])
  @@index([tenantId])
  @@map("promo_redemptions")
}

model SubscriptionGrant {
  id              String    @id
  tenantId        String    @map("tenant_id")
  planCode        String    @map("plan_code")
  grantType       String    @map("grant_type") // free_trial|free_period|free_forever|manual_discount|internal
  startsAt        DateTime  @default(now()) @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  durationCount   Int?      @map("duration_count")
  durationUnit    String?   @map("duration_unit") // day|month|year|lifetime
  reason           String?
  grantedByUserId  Int?      @map("granted_by_user_id")
  isActive         Boolean   @default(true) @map("is_active")
  featuresOverride Json?     @map("features_override")
  raw              Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("subscription_grants")
}

/**
 * ── Mailing transactionnel & campagnes (mini-Brevo) ───────────────────────
 * Envoi via SMTP o2switch. Aucun secret stocké en base (env only).
 */
model MailLayout {
  id          String   @id
  name        String
  isDefault   Boolean  @default(false) @map("is_default")
  htmlWrapper String   @map("html_wrapper") // doit contenir {{content}}
  raw         Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("mail_layouts")
}

model MailTemplate {
  id          String   @id
  key         String   @unique // ex: billing.invoice_issued
  name        String
  category    String   @default("system") // account|billing|subscription|support|system|marketing
  subject     String
  htmlBody    String   @map("html_body")
  textBody    String?  @map("text_body")
  locale      String   @default("fr-FR")
  enabled     Boolean  @default(true)
  layoutId    String?  @map("layout_id")
  description String?
  variables   Json? // liste indicative des variables
  isMarketing Boolean  @default(false) @map("is_marketing")
  preheader   String?
  // Variantes responsive éditées séparément : { desktop:{html,css}, tablet:{…}, mobile:{…} }.
  responsiveVariants Json? @map("responsive_variants")
  raw         Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([category])
  @@map("mail_templates")
}

model MailQueue {
  id                String    @id
  tenantId          String?   @map("tenant_id")
  toEmail           String    @map("to_email")
  toName            String?   @map("to_name")
  templateKey       String?   @map("template_key")
  category          String    @default("system")
  subject           String
  htmlBody          String    @map("html_body")
  textBody          String?   @map("text_body")
  status            String    @default("pending") // pending|sending|sent|failed|canceled|skipped
  attempts          Int       @default(0)
  maxAttempts       Int       @default(5) @map("max_attempts")
  lastError         String?   @map("last_error")
  scheduledAt       DateTime  @default(now()) @map("scheduled_at")
  sentAt            DateTime? @map("sent_at")
  providerMessageId String?   @map("provider_message_id")
  campaignId        String?   @map("campaign_id")
  dedupeKey         String?   @unique @map("dedupe_key")
  meta              Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([tenantId])
  @@index([campaignId])
  @@map("mail_queue")
}

model MailEvent {
  id        String   @id
  queueId   String?  @map("queue_id")
  tenantId  String?  @map("tenant_id")
  type      String // queued|sent|failed|skipped|retry|opened|unsubscribed
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([queueId])
  @@index([tenantId])
  @@map("mail_events")
}

model MailPreference {
  id           String   @id
  email        String
  tenantId     String?  @map("tenant_id")
  token        String   @unique // pour lien de désinscription
  unsubAll     Boolean  @default(false) @map("unsub_all")
  unsubMarketing Boolean @default(false) @map("unsub_marketing")
  categories   Json? // map catégorie -> bool (désinscrit)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([email, tenantId])
  @@map("mail_preferences")
}

model MailCampaign {
  id          String    @id
  name        String
  templateKey String?   @map("template_key")
  subject     String?
  htmlBody    String?   @map("html_body")
  category    String    @default("marketing")
  status      String    @default("draft") // draft|scheduled|sending|sent|canceled
  audience    Json? // { scope: "all"|"plan"|"status", value?: string }
  scheduledAt DateTime? @map("scheduled_at")
  sentCount   Int       @default(0) @map("sent_count")
  failedCount Int       @default(0) @map("failed_count")
  createdByUserId Int?  @map("created_by_user_id")
  raw         Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@map("mail_campaigns")
}

/**
 * ── Support humain / chat conseiller ──────────────────────────────────────
 * Conversations cloisonnées par tenant (un client ne voit QUE son tenant).
 * Séparation IA / humain via `channel` + `author_type`.
 */
model SupportConversation {
  id               String    @id
  tenantId         String    @map("tenant_id")
  ref              String    @unique // référence courte lisible (ex: SUP-0001)
  subject          String
  status           String    @default("open") // open|pending|waiting_customer|resolved|closed
  channel          String    @default("chat") // chat|ticket|ai
  priority         String    @default("normal") // low|normal|high|urgent
  category         String?
  createdByUserId  Int?      @map("created_by_user_id")
  createdByName    String?   @map("created_by_name")
  assignedToUserId Int?      @map("assigned_to_user_id")
  lastMessageAt    DateTime? @map("last_message_at")
  customerUnread   Int       @default(0) @map("customer_unread")
  agentUnread      Int       @default(0) @map("agent_unread")
  firstResponseAt  DateTime? @map("first_response_at")
  resolvedAt       DateTime? @map("resolved_at")
  closedAt         DateTime? @map("closed_at")
  slaDueAt         DateTime? @map("sla_due_at")
  slaBreached      Boolean   @default(false) @map("sla_breached")
  ratingScore      Int?      @map("rating_score")
  ratingComment    String?   @map("rating_comment")
  meta             Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@index([assignedToUserId])
  @@map("support_conversations")
}

model SupportMessage {
  id             String   @id
  conversationId String   @map("conversation_id")
  tenantId       String   @map("tenant_id")
  authorType     String   @map("author_type") // customer|agent|ai|system
  authorUserId   Int?     @map("author_user_id")
  authorName     String?  @map("author_name")
  body           String
  isInternal     Boolean  @default(false) @map("is_internal") // note interne (jamais visible client)
  meta           Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([tenantId])
  @@map("support_messages")
}

model SupportAttachment {
  id             String   @id
  messageId      String?  @map("message_id")
  conversationId String   @map("conversation_id")
  tenantId       String   @map("tenant_id")
  filename       String
  mimeType       String?  @map("mime_type")
  sizeBytes      Int?     @map("size_bytes")
  storageKey     String   @map("storage_key")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("support_attachments")
}

model SupportSlaPolicy {
  id                String   @id
  name              String
  priority          String   @default("normal")
  firstResponseMins Int      @map("first_response_mins")
  resolutionMins    Int      @map("resolution_mins")
  isDefault         Boolean  @default(false) @map("is_default")
  raw               Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("support_sla_policies")
}

model SupportCannedReply {
  id              String   @id
  title           String
  body            String
  category        String?
  shortcut        String?
  createdByUserId Int?     @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("support_canned_replies")
}

/**
 * ── Chiffrement au repos par tenant (enveloppe) ───────────────────────────
 * La DEK (clé de données du tenant) n'est JAMAIS stockée en clair : elle est
 * chiffrée (wrapped) avec la KEK maître (ENCRYPTION_MASTER_KEY) via AES-256-GCM.
 */
model TenantEncryptionKey {
  id          String   @id
  tenantId    String   @unique @map("tenant_id")
  wrappedDek  String   @map("wrapped_dek") // base64(iv|tag|ciphertext) — DEK chiffrée par la KEK
  algo        String   @default("aes-256-gcm")
  keyVersion  Int      @default(1) @map("key_version")
  status      String   @default("active") // active|rotating|retired
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenant_encryption_keys")
}

model TenantInvitation {
  id                String    @id
  tenantId          String    @map("tenant_id")
  email             String
  role              String    @default("member") // owner|admin|member|viewer
  status            String    @default("pending") // pending|accepted|expired|canceled
  tokenHash         String    @map("token_hash")
  invitedByUserId   Int?      @map("invited_by_user_id")
  acceptedByUserId  Int?      @map("accepted_by_user_id")
  expiresAt         DateTime  @map("expires_at")
  acceptedAt        DateTime? @map("accepted_at")
  canceledAt        DateTime? @map("canceled_at")
  lastSentAt        DateTime? @map("last_sent_at")
  sendCount         Int       @default(0) @map("send_count")
  message           String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@map("tenant_invitations")
}

model TenantDomain {
  id                 String    @id
  tenantId           String    @map("tenant_id")
  domain             String    @unique
  type               String    @default("subdomain") // subdomain|custom_domain
  status             String    @default("pending") // pending|active|failed|disabled
  isPrimary          Boolean   @default(false) @map("is_primary")
  verificationToken  String?   @map("verification_token")
  verificationStatus String    @default("pending") @map("verification_status") // pending|verified|failed
  sslStatus          String    @default("pending") @map("ssl_status") // pending|active|failed|not_required
  dnsStatus          String    @default("pending") @map("dns_status") // pending|valid|invalid
  lastCheckedAt      DateTime? @map("last_checked_at")
  verifiedAt         DateTime? @map("verified_at")
  activatedAt        DateTime? @map("activated_at")
  disabledAt         DateTime? @map("disabled_at")
  raw                Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("tenant_domains")
}

model SecurityEvent {
  id                String    @id
  tenantId          String?   @map("tenant_id")
  userId            Int?      @map("user_id")
  actorUserId       Int?      @map("actor_user_id")
  eventType         String    @map("event_type")
  category          String    @default("info") // auth|tenant|billing|support|encryption|access|system
  severity          String    @default("info") // info|warning|critical
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  targetType        String?   @map("target_type")
  targetId          String?   @map("target_id")
  message           String
  metadata          Json?
  status            String    @default("open") // open|reviewed|ignored|resolved
  reviewedAt        DateTime? @map("reviewed_at")
  reviewedByUserId  Int?      @map("reviewed_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([eventType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("security_events")
}

model UserMfa {
  id            String    @id
  userId        Int       @unique @map("user_id")
  method        String    @default("totp")
  secretEnc     String    @map("secret_enc") // base64(iv|tag|ct) — secret TOTP chiffré (jamais en clair)
  enabled       Boolean   @default(false)
  confirmedAt   DateTime? @map("confirmed_at")
  backupCodes   Json?     @map("backup_codes") // [{ hash, usedAt }]
  lastUsedAt    DateTime? @map("last_used_at")
  failedCount   Int       @default(0) @map("failed_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("user_mfa")
}

model SaasSettings {
  id        String   @id // "global"
  data      Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("saas_settings")
}

model EncryptionMigrationRun {
  id          String   @id
  startedAt   DateTime @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  dryRun      Boolean  @default(false) @map("dry_run")
  found       Int      @default(0)
  alreadyEnc  Int      @default(0) @map("already_encrypted")
  encrypted   Int      @default(0)
  skipped     Int      @default(0)
  errors      Int      @default(0)
  details     Json?

  @@map("encryption_migration_runs")
}
